# ==========================================
# CV System - Gitignore
#
# ==========================================
#-------Offers
/offers/*.md
# --- Knowledge base (profile, experience, skills, etc.) ---
kb/*.yaml
kb/**/*.yaml

# --- Generated CVs ---
# Outputs contain CVs with personal information
outputs/

# --- PDF files ---
# Personal CV PDFs used for ingestion
*.pdf

# --- Python ---
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# --- Virtual environments ---
venv/
.venv/
env/
.env

# --- IDEs ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- Operating system ---
.DS_Store
Thumbs.db
desktop.ini

# --- Temporary files ---
*.tmp
*.bak
*.log
